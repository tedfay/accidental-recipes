# Biga-MCP environment template.
# Copy to .env (gitignored) and fill in. Loaded by `npm run dev` via tsx --env-file=.env.

# Postgres connection — Supabase session pooler URL.
# Same value the frontend uses for local dev.
DATABASE_URL=

# MCP HTTP auth keys (only required when running in HTTP mode, e.g. on Railway).
# Two distinct values — read tools accept either, write tools require WRITE.
MCP_API_KEY_READ=
MCP_API_KEY_WRITE=

# IndexNow integration — frontend webhook + shared secret.
FRONTEND_URL=
INDEXNOW_SUBMIT_KEY=

# Supabase Storage — image upload pipeline (2FI-215).
# SERVICE ROLE KEY is highly privileged. Local dev only — production lives on Railway.
# Never set on Netlify and never commit.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
