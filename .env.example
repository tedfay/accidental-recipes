# Supabase Session pooler URL (not the direct URL)
# Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
# Get this from: Supabase dashboard → Settings → Database → Connection string → Session pooler
# The direct URL (db.[ref].supabase.co) will fail due to DNS resolution on home networks.
DATABASE_URL=

# Supabase project URL — used to compose public image URLs at read time (2FI-215).
# Format: https://[ref].supabase.co
# Public-safe value. NEVER put SUPABASE_SERVICE_ROLE_KEY in the frontend —
# that key is server-only and lives in Biga-MCP/.env (local) + Railway env (prod).
NEXT_PUBLIC_SUPABASE_URL=
